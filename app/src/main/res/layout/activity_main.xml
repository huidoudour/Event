<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ui.HomeActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:liftOnScroll="true"
        style="@style/Widget.Material3.AppBarLayout">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="@string/app_name"
            app:titleCentered="false"
            style="@style/Widget.Material3.Toolbar">

            <!-- Settings Button -->
            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_button_circle_ripple"
                android:contentDescription="@string/settings"
                android:src="@drawable/ic_settings"
                android:scaleType="centerInside"
                android:padding="12dp" />

            <!-- Sort Order Toggle Button -->
            <ImageButton
                android:id="@+id/btnSortOrder"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_button_circle_ripple"
                android:contentDescription="@string/toggle_sort_order"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:scaleType="centerInside"
                android:padding="12dp" />

            <!-- Refresh Button -->
            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_button_circle_ripple"
                android:contentDescription="@string/refresh"
                android:src="@android:drawable/ic_menu_rotate"
                android:scaleType="centerInside"
                android:padding="12dp" />

            <!-- Clear All Button (Long Press) -->
            <ImageButton
                android:id="@+id/btnClearAll"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_button_circle_ripple"
                android:contentDescription="@string/clear_all"
                android:src="@android:drawable/ic_menu_delete"
                android:scaleType="centerInside"
                android:padding="12dp" />

            <!-- Multi-Select Button -->
            <ImageButton
                android:id="@+id/btnMultiSelect"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_button_circle_ripple"
                android:contentDescription="@string/multi_select"
                android:src="@android:drawable/ic_menu_agenda"
                android:scaleType="centerInside"
                android:padding="12dp" />

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="80dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        tools:listitem="@layout/item_event" />

    <TextView
        android:id="@+id/emptyView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/no_events"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:visibility="gone" />

    <!-- 批量操作按钮组（多选模式下显示，位于FAB上方，竖向排列） -->
    <LinearLayout
        android:id="@+id/batchActionContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="88dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="gone">

        <!-- 全选按钮（圆形，无阴影，与FAB同大小） -->
        <ImageButton
            android:id="@+id/btnSelectAll"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_circle_secondary"
            android:contentDescription="@string/select_all"
            android:src="@android:drawable/ic_menu_agenda"
            android:scaleType="centerInside"
            android:padding="12dp" />

        <!-- 删除所选按钮（圆形，错误颜色，无阴影，与FAB同大小） -->
        <ImageButton
            android:id="@+id/btnDeleteSelected"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_error"
            android:contentDescription="@string/delete_selected"
            android:src="@android:drawable/ic_menu_delete"
            android:scaleType="centerInside"
            android:padding="12dp" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddEvent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/add_event"
        android:src="@drawable/ic_add"
        app:tint="@color/black"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        style="@style/Widget.Material3.FloatingActionButton.Primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
