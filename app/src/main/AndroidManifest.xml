<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Event">
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- 彩色图标别名 -->
        <activity-alias
            android:name=".MainActivityColorful"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_colorful"
            android:roundIcon="@mipmap/ic_launcher_round_colorful"
            android:targetActivity=".ui.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="true"
            android:label="@string/settings" />
        
        <activity
            android:name=".ui.MeActivity"
            android:exported="false"
            android:label="@string/about_developer" />

        <activity
            android:name=".ui.ListViewActivity"
            android:exported="false"
            android:label="@string/list_view" />

        <meta-data
            android:name="me.huidoudour.core"
            android:value="true" />
        <meta-data
            android:name="me.huidoudour.core.version"
            android:value="23" />

    </application>

</manifest>